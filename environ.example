$project_workdir="$PSScriptRoot"
$debugFolder=$(join-path "$project_workdir" "debug")
$errors_folder=$(join-path $debugFolder "errors")
$script:GLOBAL_ERRORS_DIRECTORY="$errors_folder"

# This folder is for migration-level errors to be written
$script:ITG_ERRORS_DIRECTORY=$(join-path "$errors_folder" "itglue")

# This is the settings folder for your migration preferences and secure-stringified secrets
$settings_folder=$(join-path "$project_workdir" "debug\settings")

# This is for your JSONified state-saving and records saving
$logs_folder=$(join-path "$project_workdir" "debug\logs")

# This is your main settings json
$defaultSettingsPath=$(join-path "$settings_folder" "settings.json")

# Clear paths during main run. Be sure to comment out below if subsequent actions being taken
foreach ($folder in @($debugFolder, $errors_folder, $logs_folder, $settings_folder, $ITG_ERRORS_DIRECTORY)) {
    if ([string]::IsNullOrWhiteSpace($folder)){continue}
    if (!(Test-Path -Path "$folder")) { New-Item "$folder" -ItemType Directory }
#    Get-ChildItem -Path "$folder" -File -Recurse -Force | Remove-Item -Force
}

$InitType = "full"
$settings = @{
    HuduBaseDomain          = "https://changeme.huducloud.com" # Note- Keep this URL Format. No trailing slashes, please
    ITGURL                  = "https://changeme.itglue.com"    # Note- Keep this URL Format. No trailing slashes, please
    ITGAPIEndpoint          = "https://api.itglue.com"         # Note- Keep this URL Format. No trailing slashes, please
    customBrandedDomain     = "n"
    ITGCustomDomains        = ""
    InternalCompany         = "changeme inc."

    # If $true, internal-company documents stay under that company instead of Hudu Global KB
    PlaceInternalDocsInInternalCompany = $false

    # Central folder KB articles when using Global KB for internal-company documents
    GlobalKBFolder          = "n"

    # Configs asset layout in Hudu Naming Prefix
    ConPromptPrefix         = ""

    # Flexible asset layout in Hudu Naming Prefix
    FAPromptPrefix          = ""

    # Absolute path to 7zip-extracted export
    ITGLueExportPath        = "c:\tmp\export"

    # Alternative logs folder?
    MigrationLogs           = "$logs_folder"

    # include ITGlue ID in Contacts, Websites, Locations
    IncludeITGlueID            = $true

    # Split configurations into individual asset layouts y/n
    SplitConfigurations     = $true
}

# Primary Secrets
$ITGKey                     = "ITG.key"
$HuduApiKey                 = "HUDU.key"

$choice                     = "N"

# settings folder path
$importChoice               = "$settings_folder"

# Custom regex capture groups / url replacement
$customBrandedDomain        = "n"

# Resume if starting again
$resumeQuestion             = "yes"
$reenterChoice              = "Continue"

# Individual Import Options, below, (1-yes, 2-no)
$ImportCompanies            = 1
$ImportLocations            = 1
$ImportDomains              = 1
$DisableWebsiteMonitoring   = 1
$ImportConfigurations       = 1
$ImportContacts             = 1
$ImportFlexibleAssetLayouts = 1
$ImportFlexibleAssets       = 1
$ImportArticles             = 1
$ImportPasswords            = 1
$OptionalImageAnchorReplace = 1
$ImportConfigInterfaces     = 1 # this creates IPAM addresses + networks in Hudu

# If you want to have script wait for user interaction between steps. Select 1 for yes, 2 for noninteractive/no
$NonInteractive             = 2

# these require JWT authentication to perform [default is 1/false; 2 for true]
$importPasswordFolders      = 2
$importChecklists           = 1
$GlobalPasswordFolderMode = $true # or $false
$PasswordFolderNameDelimiter = " - " # seperator when concatenating folders in squashed / flattened password folder
$FolderNamingMode = "Name Based on Full Path with Delimiter" # how to name the password folders which get flattened in hudu.
                    # "Name Based on Root-Level-Directory"
                    # "Name Based on Current/Leaf-Level Directory"

# If you want to scope migration to just come companies, select 2, otherwise leave at 1 for typical, full migration
$ScopedMigration            = 1
$MergedOrganizationTypes    = 1

# do you want to skip flexible asset layouts from integrators? they are generally have the phrase '(auto)' in the name

$skipIntegratorLayouts = $true
$OptionalImageAnchorReplace = $true # best to leave this set to 'true'. it replaces anchors to images with the image URL in Hudu.

# Apply flags and flag types during the migration; requires Hudu 2.40+
$allowSettingFlagsAndTypes  = $false

# pre-designated array/list of prescoped/preselected companies for scoped migration (typically for faster testing)
# prescoped Companies
# $Prescoped = @(
# 905
# 859
#)

$LocImportAssetLayoutName = "Locations" # name for locations layout
$ConImportAssetLayoutName = "People" # name for contacts/people layout
$IncludeIgnoredFirstArticleDirectory = $true # set this to 'false' to exclude the root level article folders (previously excluding these top level folders was expected behavior)

. .\ITGlue-Hudu-Migration.ps1
